@page "/Error"
@using System.Diagnostics

<PageTitle>Ошибка</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Style="margin-top: 4rem;">
    <RadzenColumn Size="12" SizeMD="8" SizeLG="6">

        <!-- Карточка с сообщением об ошибке -->
        <RadzenCard Variant="Variant.Filled" Style="padding: 2rem; border-left: 4px solid var(--rz-danger);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Style="margin-bottom: 1.5rem;">
                <RadzenIcon Icon="error" IconColor="var(--rz-danger)" Style="font-size: 3rem; width: 48px; height: 48px;" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="rz-color-danger" Style="margin: 0;">
                        Произошла ошибка
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">
                        Во время обработки вашего запроса что-то пошло не так.
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>

            <!-- Блок с ID запроса -->
            @if (ShowRequestId)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" AllowClose="false" Style="margin-bottom: 1.5rem;">
                    <strong>ID запроса:</strong> <code>@RequestId</code>
                </RadzenAlert>
            }

            <!-- Информационный блок о режиме разработки -->
            <RadzenCard Variant="Variant.Outlined" Style="background: var(--rz-neutral-200); padding: 1.5rem;">
                <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H3" Style="margin-top: 0;">
                    Режим разработки (Development Mode)
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-bottom: 0.5rem;">
                    Переключение в среду <strong>Development</strong> отобразит более подробную информацию об ошибке.
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="rz-text-bold rz-color-danger" Style="margin-bottom: 0.5rem;">
                    Среду разработки не следует включать в развернутых приложениях!
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-bottom: 0;">
                    Это может привести к показу конфиденциальных данных из исключений конечным пользователям.
                    Для локальной отладки установите переменную среды <strong>ASPNETCORE_ENVIRONMENT</strong> в значение <strong>Development</strong> и перезапустите приложение.
                </RadzenText>
            </RadzenCard>

            <!-- Кнопка возврата на главную -->
            <RadzenStack AlignItems="AlignItems.Center" Style="margin-top: 2rem;">
                <RadzenButton Text="Вернуться на главную" Path="" Icon="home" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Primary" />
            </RadzenStack>

        </RadzenCard>

    </RadzenColumn>
</RadzenRow>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
